#### 4. **Recherche Sémantique Simple** (TF-IDF basique)
```javascript
function searchKnowledge(query, database) {
  const queryTokens = tokenize(query.toLowerCase());
  let bestMatch = null;
  let bestScore = 0;

  database.forEach(item => {
    let score = 0;
    item.keywords.forEach(keyword => {
      if (queryTokens.includes(keyword.toLowerCase())) {
        score += 1;
      }
    });
    
    if (score > bestScore) {
      bestScore = score;
      bestMatch = item;
    }
  });

  return bestScore > 0 ? bestMatch : null;
}

function tokenize(text) {
  return text.split(/\s+/).filter(t => t.length > 2);
}
```

